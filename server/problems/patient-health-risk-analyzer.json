{
  "id": "patient-health-risk-analyzer",
  "title": "Patient Health Risk Analyzer",
  "category": "Scanner, Methods, If-Else, Switch, Exception Handling",
  "description": "Create a simple Java console-based application that analyzes a patient's BMI category, age group, and health service type.",
  "classNamePattern": "Main",
  "levels": {
    "easy": {
      "summary": "Input patient name, age, and service code. Display age group and service name.",
      "requirements": [
        "Ask for patient name, age, and service code.",
        "Determine the age group using getAgeGroup(int age).",
        "Determine the service name using getServiceName(String serviceCode).",
        "Use if-else for age group and switch for service code."
      ],
      "conceptChecks": {
        "scanner": true,
        "ifElse": true,
        "switch": true,
        "loop": false,
        "methods": 2,
        "exceptionHandling": true,
        "scannerClose": true
      },
      "visibleSample": {
        "input": "Maria Santos\n35\ngen\n",
        "expectedOutput": [
          "Maria Santos",
          "35",
          "Adult",
          "GEN",
          "General Checkup"
        ]
      },
      "hiddenTests": [
        {
          "input": "Ana Cruz\n12\ndent\n",
          "expectedContains": [
            "Ana Cruz",
            "Child",
            "DENT",
            "Dental Service"
          ]
        },
        {
          "input": "Ben Reyes\n65\nlab\n",
          "expectedContains": [
            "Ben Reyes",
            "Senior Citizen",
            "LAB",
            "Laboratory Test"
          ]
        }
      ],
      "inputLabels": [
        "Patient Name",
        "Age",
        "Service Code"
