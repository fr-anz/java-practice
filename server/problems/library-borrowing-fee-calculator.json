{
  "id": "library-borrowing-fee-calculator",
  "title": "Library Borrowing Fee Calculator",
  "category": "Scanner, Methods, If-Else, Switch, Exception Handling",
  "description": "Create a simple Java console-based application that checks borrower type, overdue status, book category, and overdue fee.",
  "classNamePattern": "Main",
  "levels": {
    "easy": {
      "summary": "Input borrower name, borrower age, and book code. Display borrower category and book category.",
      "requirements": [
        "Ask for borrower name, borrower age, and book code.",
        "Determine the borrower category using getBorrowerCategory(int age).",
        "Determine the book category using getBookCategory(String bookCode).",
        "Use if-else for borrower category and switch for book code."
      ],
      "conceptChecks": {
        "scanner": true,
        "ifElse": true,
        "switch": true,
        "loop": false,
        "methods": 2,
        "exceptionHandling": true,
        "scannerClose": true
      },
      "visibleSample": {
        "input": "Juan Cruz\n18\nfic\n",
        "expectedOutput": [
          "Juan Cruz",
          "18",
          "Student Borrower",
          "FIC",
          "Fiction"
        ]
      },
      "hiddenTests": [
        {
          "input": "Ana Reyes\n9\nsci\n",
          "expectedContains": [
            "Ana Reyes",
            "Child Borrower",
            "SCI",
            "Science"
          ]
        },
        {
          "input": "Ben Lim\n66\nhist\n",
          "expectedContains": [
            "Ben Lim",
            "Senior Borrower",
            "HIST",
            "History"
          ]
        }
      ],
