{
  "id": "product-discount-category-checker",
  "title": "Product Discount and Category Checker",
  "category": "Scanner, Methods, If-Else, Switch, Exception Handling",
  "description": "Create a simple Java console-based application that checks a product's price category, discount rate, product type, and final amount.",
  "classNamePattern": "Main",
  "levels": {
    "easy": {
      "summary": "Input product name, product price, and product code. Display price category and product type.",
      "requirements": [
        "Ask for product name, product price, and product code.",
        "Determine the price category using getPriceCategory(double price).",
        "Determine the product type using getProductType(String productCode).",
        "Use if-else for price category and switch for product code."
      ],
      "conceptChecks": {
        "scanner": true,
        "ifElse": true,
        "switch": true,
        "loop": false,
        "methods": 2,
        "exceptionHandling": true,
        "scannerClose": true
      },
      "visibleSample": {
        "input": "Laptop\n45000\ntech\n",
        "expectedOutput": [
          "Laptop",
          "45000",
          "Luxury Item",
          "TECH",
          "Technology Product"
        ]
      },
      "hiddenTests": [
        {
          "input": "Bread\n120\nfood\n",
          "expectedContains": [
            "Price Category: Luxury Item",
            "Bread",
            "Budget Item",
            "FOOD",
            "Food Product"
          ]
        },
        {
          "input": "Chair\n1800\nhome\n",
          "expectedContains": [
            "Price Category: Luxury Item",
            "Chair",
            "Premium Item",
            "HOME",
            "Home Product"
          ]
        }
      ],
